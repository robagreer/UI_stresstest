<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>UI Trust Fund Stress-Test: Interactive Scenario Analysis</title>
<script src="https://cdn.plot.ly/plotly-2.32.0.min.js"></script>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Segoe UI', system-ui, -apple-system, sans-serif; background: #f8fafc; color: #0f172a; min-height: 100vh; }
  a { color: inherit; }

  /* ── Layout ── */
  .page { max-width: 1060px; margin: 0 auto; padding: 20px 18px; }
  .header { margin-bottom: 18px; }
  .header h1 { font-size: 18px; font-weight: 700; }
  .header p  { font-size: 12px; color: #64748b; margin-top: 5px; line-height: 1.5; }
  .grid { display: grid; grid-template-columns: 1fr 296px; gap: 16px; }
  .card { background: white; border-radius: 12px; border: 1px solid #e2e8f0; padding: 18px; }

  /* ── Preset toggle buttons ── */
  .toggle-label { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .07em; color: #94a3b8; margin-bottom: 9px; }
  .presets { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 16px; }
  .preset-btn {
    padding: 4px 11px; border-radius: 20px; font-size: 11px; font-weight: 600;
    cursor: pointer; border: 2px solid; transition: background .15s, color .15s;
    background: white; font-family: inherit;
  }
  .preset-btn.on { color: white; }

  /* ── Chart ── */
  #chart { width: 100%; height: 370px; }
  .chart-note { font-size: 10.5px; color: #94a3b8; text-align: center; margin-top: 8px; }

  /* ── Right panel ── */
  .metrics {
    border-radius: 10px; padding: 14px; margin-bottom: 12px;
    border: 1px solid #bbf7d0; background: #f0fdf4;
    transition: background .3s, border-color .3s;
  }
  .metrics.bad { border-color: #fecdd3; background: #fff1f2; }
  .metrics-title { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; color: #15803d; margin-bottom: 10px; }
  .metrics.bad .metrics-title { color: #dc2626; }
  .metrics-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
  .metric { background: white; border-radius: 8px; padding: 8px 10px; border: 1px solid #e2e8f0; }
  .metric.wide { grid-column: span 2; }
  .metric-label { font-size: 10px; color: #94a3b8; margin-bottom: 2px; }
  .metric-value { font-size: 15px; font-weight: 700; color: #15803d; }
  .metric-value.bad { color: #dc2626; }

  /* ── Slider controls ── */
  .controls-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 14px; }
  .controls-title { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; color: #475569; }
  .quick-btns { display: flex; gap: 5px; }
  .quick-btn { font-size: 10px; padding: 3px 9px; border-radius: 6px; border: 1px solid; background: white; cursor: pointer; font-weight: 600; font-family: inherit; }

  .section-hdr { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; color: #94a3b8; margin: 14px 0 8px; padding-top: 12px; border-top: 1px solid #f1f5f9; }
  .section-hdr.first { border-top: none; padding-top: 0; margin-top: 0; }

  .slider-row { margin-bottom: 11px; }
  .slider-labels { display: flex; justify-content: space-between; font-size: 12px; margin-bottom: 3px; }
  .slider-name  { color: #334155; }
  .slider-value { color: #7c3aed; font-weight: 700; font-family: 'Courier New', monospace; }
  input[type=range] { width: 100%; accent-color: #7c3aed; cursor: pointer; display: block; }

  /* ── Footer ── */
  .footer { font-size: 11px; color: #94a3b8; text-align: center; margin-top: 14px; line-height: 1.6; }

  @media (max-width: 740px) {
    .grid { grid-template-columns: 1fr; }
  }
</style>
</head>
<body>
<div class="page">

  <!-- Header -->
  <div class="header">
    <h1>UI Trust Fund Stress-Test: Interactive Scenario Analysis</h1>
    <p>
      Greer, R. A. — <em>Stress-Testing the Safety Net: AI-Driven Displacement and U.S. Unemployment Insurance Fund Solvency</em><br>
      F(t) = F(t−1) + τ·W<sub>eff</sub>·E(t) − [B₀ + p·Δt·w̄·d̄] &nbsp;|&nbsp;
      F₀ = $70B &nbsp;·&nbsp; E₀ = 155M workers &nbsp;·&nbsp; B₀ = $27B/yr baseline benefits
    </p>
  </div>

  <div class="grid">

    <!-- ── Left: Chart panel ── -->
    <div class="card">
      <div class="toggle-label">Paper Scenarios — click to show / hide</div>
      <div class="presets" id="presetBtns"></div>
      <div id="chart"></div>
      <p class="chart-note">
        Solid lines = Baseline (Panel A) parameters &nbsp;·&nbsp; Dashed lines = Upper-Tail Stress (Panel B) parameters &nbsp;·&nbsp; Purple = Custom
      </p>
    </div>

    <!-- ── Right: Controls panel ── -->
    <div>
      <!-- Metrics -->
      <div class="metrics" id="metricsPanel">
        <div class="metrics-title">Custom Scenario Metrics</div>
        <div class="metrics-grid">
          <div class="metric"><div class="metric-label">Year-5 Balance</div><div class="metric-value" id="mY5">—</div></div>
          <div class="metric"><div class="metric-label">Year-10 Balance</div><div class="metric-value" id="mY10">—</div></div>
          <div class="metric wide"><div class="metric-label">Depletion Year</div><div class="metric-value" id="mDep">—</div></div>
        </div>
      </div>

      <!-- Sliders -->
      <div class="card">
        <div class="controls-header">
          <span class="controls-title">Custom Parameters</span>
          <div class="quick-btns">
            <button class="quick-btn" style="color:#15803d;border-color:#15803d" id="btnBaseline">↺ Baseline</button>
            <button class="quick-btn" style="color:#dc2626;border-color:#dc2626" id="btnUpperTail">↺ Upper-Tail</button>
          </div>
        </div>
        <div id="slidersContainer"></div>
      </div>
    </div>
  </div>

  <p class="footer">
    Model: F(t) = F(t−1) + τ·W<sub>eff</sub>·E(t) − [B₀ + p·Δt·w̄·d̄] &nbsp;|&nbsp;
    E(t) = max(0, E₀ − cumulative displaced) &nbsp;|&nbsp;
    Δt = D/N for years 1…N, then 0 &nbsp;|&nbsp;
    Revenue units: (τ/100) × W<sub>eff</sub><sub>$K</sub> × E<sub>M</sub> = $B &nbsp;|&nbsp;
    Claims units: (p/100) × Δt<sub>M</sub> × w̄<sub>$/wk</sub> × d̄<sub>wks</sub> ÷ 1000 = $B
  </p>
</div>

<script>
// ═══════════════════════════════════════════════════════════════════════════════
// MODEL
// ═══════════════════════════════════════════════════════════════════════════════
const E0 = 155, F0 = 70, B0 = 27, YEARS = 12;

function simulate({ D, N, tau, Weff, p, wavg, davg }) {
  const bal = [F0];
  let fund = F0;
  for (let t = 1; t <= YEARS; t++) {
    const prevCum = Math.min(D, ((t - 1) / N) * D);
    const employ  = Math.max(0, E0 - prevCum);
    const newD    = t <= N ? D / N : 0;
    const revenue = (tau / 100) * Weff * employ;
    const claims  = (p   / 100) * newD * wavg * davg / 1000;
    fund = fund + revenue - (B0 + claims);
    bal.push(+fund.toFixed(1));
  }
  return bal;
}

function depYear(bal) {
  for (let i = 1; i < bal.length; i++) if (bal[i] <= 0) return i;
  return null;
}

// ═══════════════════════════════════════════════════════════════════════════════
// SCENARIOS  (match paper's Panel A / Panel B parameter sets)
// ═══════════════════════════════════════════════════════════════════════════════
const SCENARIOS = [
  { id:0, label:"Moderate · Baseline",       D:6.5, N:5, tau:.80, Weff:22, p:35, wavg:420, davg:18, color:"#1d4ed8", dash:"solid" },
  { id:1, label:"Moderate · Upper-Tail",     D:6.5, N:5, tau:.80, Weff:15, p:55, wavg:480, davg:26, color:"#60a5fa", dash:"dash"  },
  { id:2, label:"Significant · Baseline",    D:15,  N:5, tau:.80, Weff:22, p:35, wavg:420, davg:18, color:"#15803d", dash:"solid" },
  { id:3, label:"Significant · Upper-Tail",  D:15,  N:5, tau:.80, Weff:15, p:55, wavg:480, davg:26, color:"#4ade80", dash:"dash"  },
  { id:4, label:"Severe · Baseline",         D:30,  N:5, tau:.80, Weff:22, p:35, wavg:420, davg:18, color:"#b91c1c", dash:"solid" },
  { id:5, label:"Severe · Upper-Tail",       D:30,  N:5, tau:.80, Weff:15, p:55, wavg:480, davg:26, color:"#f87171", dash:"dash"  },
];

// Pre-compute preset balances
const PRESET_SIMS = SCENARIOS.map(simulate);

// ═══════════════════════════════════════════════════════════════════════════════
// STATE
// ═══════════════════════════════════════════════════════════════════════════════
const visible = new Set([0, 2, 4]);   // default: show three baselines
let showCustom = true;

let custom = { D:15, N:5, tau:0.80, Weff:22, p:35, wavg:420, davg:18 };

// ═══════════════════════════════════════════════════════════════════════════════
// SLIDER DEFINITIONS
// ═══════════════════════════════════════════════════════════════════════════════
const SLIDERS = [
  { section:"Displacement", first:true },
  { key:"D",    label:"Total Displaced",           min:1,    max:40,  step:0.5,  fmt: v=>`${v}M jobs`       },
  { key:"N",    label:"Displacement Horizon",      min:1,    max:10,  step:1,    fmt: v=>`${v} years`       },
  { section:"Revenue Drivers" },
  { key:"tau",  label:"SUTA Rate (τ)",              min:0.30, max:3.0, step:0.05, fmt: v=>`${v.toFixed(2)}%`},
  { key:"Weff", label:"Effective Wage Base (W_eff)",min:7,    max:50,  step:1,    fmt: v=>`$${v}K`           },
  { section:"Benefit Drivers" },
  { key:"p",    label:"UI Participation Rate (p)",  min:15,   max:80,  step:1,    fmt: v=>`${v}%`            },
  { key:"wavg", label:"Avg Weekly Benefit (w̄)",    min:250,  max:700, step:10,   fmt: v=>`$${v}/wk`         },
  { key:"davg", label:"Avg Claim Duration (d̄)",    min:10,   max:36,  step:1,    fmt: v=>`${v} wks`         },
];

// ═══════════════════════════════════════════════════════════════════════════════
// BUILD PRESET TOGGLE BUTTONS
// ═══════════════════════════════════════════════════════════════════════════════
function buildPresetButtons() {
  const container = document.getElementById("presetBtns");

  SCENARIOS.forEach(scen => {
    const btn = document.createElement("button");
    btn.className = "preset-btn" + (visible.has(scen.id) ? " on" : "");
    btn.textContent = scen.label;
    btn.style.borderColor = scen.color;
    btn.style.color       = visible.has(scen.id) ? "white" : scen.color;
    btn.style.background  = visible.has(scen.id) ? scen.color : "white";
    btn.addEventListener("click", () => {
      if (visible.has(scen.id)) {
        visible.delete(scen.id);
        btn.classList.remove("on");
        btn.style.background = "white";
        btn.style.color      = scen.color;
      } else {
        visible.add(scen.id);
        btn.classList.add("on");
        btn.style.background = scen.color;
        btn.style.color      = "white";
      }
      redrawChart();
    });
    container.appendChild(btn);
  });

  // Custom toggle
  const cBtn = document.createElement("button");
  cBtn.className = "preset-btn" + (showCustom ? " on" : "");
  cBtn.textContent = "⚙ Custom";
  cBtn.style.borderColor = "#7c3aed";
  cBtn.style.background  = showCustom ? "#7c3aed" : "white";
  cBtn.style.color        = showCustom ? "white"   : "#7c3aed";
  cBtn.addEventListener("click", () => {
    showCustom = !showCustom;
    cBtn.style.background = showCustom ? "#7c3aed" : "white";
    cBtn.style.color       = showCustom ? "white"   : "#7c3aed";
    redrawChart();
  });
  container.appendChild(cBtn);
}

// ═══════════════════════════════════════════════════════════════════════════════
// BUILD SLIDERS
// ═══════════════════════════════════════════════════════════════════════════════
function buildSliders() {
  const container = document.getElementById("slidersContainer");
  SLIDERS.forEach(item => {
    if (item.section) {
      const hdr = document.createElement("div");
      hdr.className = "section-hdr" + (item.first ? " first" : "");
      hdr.textContent = item.section;
      container.appendChild(hdr);
      return;
    }
    const valId = "val_" + item.key;
    const div = document.createElement("div");
    div.className = "slider-row";
    div.innerHTML = `
      <div class="slider-labels">
        <span class="slider-name">${item.label}</span>
        <span class="slider-value" id="${valId}">${item.fmt(custom[item.key])}</span>
      </div>
      <input type="range" id="sl_${item.key}"
        min="${item.min}" max="${item.max}" step="${item.step}" value="${custom[item.key]}">
    `;
    div.querySelector("input").addEventListener("input", function() {
      const v = parseFloat(this.value);
      custom[item.key] = v;
      document.getElementById(valId).textContent = item.fmt(v);
      if (showCustom) redrawChart();
      updateMetrics();
    });
    container.appendChild(div);
  });

  document.getElementById("btnBaseline").addEventListener("click",   () => loadPreset(0));
  document.getElementById("btnUpperTail").addEventListener("click",  () => loadPreset(1));
}

function loadPreset(idx) {
  const src = SCENARIOS[idx];
  Object.assign(custom, { D:src.D, N:src.N, tau:src.tau, Weff:src.Weff, p:src.p, wavg:src.wavg, davg:src.davg });
  SLIDERS.filter(s => s.key).forEach(item => {
    const sl = document.getElementById("sl_" + item.key);
    if (sl) sl.value = custom[item.key];
    const vl = document.getElementById("val_" + item.key);
    if (vl) vl.textContent = item.fmt(custom[item.key]);
  });
  if (showCustom) redrawChart();
  updateMetrics();
}

// ═══════════════════════════════════════════════════════════════════════════════
// CHART (Plotly)
// ═══════════════════════════════════════════════════════════════════════════════
const xVals = Array.from({ length: YEARS + 1 }, (_, i) => i);

function buildTraces() {
  const traces = [];

  // Preset traces
  SCENARIOS.forEach((scen, i) => {
    if (!visible.has(i)) return;
    traces.push({
      x: xVals,
      y: PRESET_SIMS[i],
      name: scen.label,
      mode: "lines",
      line: { color: scen.color, width: 2, dash: scen.dash },
      hovertemplate: `<b>${scen.label}</b><br>Year %{x}<br>Balance: $%{y}B<extra></extra>`
    });
  });

  // Custom trace
  if (showCustom) {
    traces.push({
      x: xVals,
      y: simulate(custom),
      name: "Custom",
      mode: "lines",
      line: { color: "#7c3aed", width: 3, dash: "solid" },
      hovertemplate: "<b>Custom</b><br>Year %{x}<br>Balance: $%{y}B<extra></extra>"
    });
  }

  return traces;
}

const LAYOUT = {
  margin: { t: 12, r: 18, l: 60, b: 48 },
  xaxis: {
    title: { text: "Year", standoff: 10 },
    dtick: 1,
    gridcolor: "#f1f5f9",
    range: [0, YEARS]
  },
  yaxis: {
    title: { text: "Trust Fund Balance ($B)" },
    gridcolor: "#f1f5f9",
    zeroline: false
  },
  shapes: [{
    type: "line",
    x0: 0, x1: YEARS, y0: 0, y1: 0,
    line: { color: "#ef4444", width: 2, dash: "dot" }
  }],
  annotations: [{
    x: YEARS - 0.3, y: 2,
    text: "Depletion threshold",
    font: { size: 10, color: "#ef4444" },
    showarrow: false, xanchor: "right"
  }],
  legend: { orientation: "h", y: -0.2, font: { size: 10 } },
  hovermode: "x unified",
  plot_bgcolor: "white",
  paper_bgcolor: "white",
  font: { family: "'Segoe UI', system-ui, sans-serif" }
};

const CONFIG = {
  responsive: true,
  displayModeBar: true,
  modeBarButtonsToRemove: ["toImage", "sendDataToCloud", "select2d", "lasso2d"],
  displaylogo: false
};

function initChart() {
  Plotly.newPlot("chart", buildTraces(), LAYOUT, CONFIG);
}

function redrawChart() {
  Plotly.react("chart", buildTraces(), LAYOUT, CONFIG);
}

// ═══════════════════════════════════════════════════════════════════════════════
// METRICS
// ═══════════════════════════════════════════════════════════════════════════════
function updateMetrics() {
  const bal  = simulate(custom);
  const dep  = depYear(bal);
  const panel = document.getElementById("metricsPanel");

  panel.classList.toggle("bad", !!dep);

  const setMetric = (id, val, good) => {
    const el = document.getElementById(id);
    el.textContent = val;
    el.className = "metric-value" + (good ? "" : " bad");
  };

  setMetric("mY5",  `$${bal[5]}B`,              bal[5]  > 0);
  setMetric("mY10", `$${bal[10]}B`,             bal[10] > 0);
  setMetric("mDep", dep ? `Year ${dep}` : "None", !dep);
}

// ═══════════════════════════════════════════════════════════════════════════════
// INIT
// ═══════════════════════════════════════════════════════════════════════════════
buildPresetButtons();
buildSliders();
initChart();
updateMetrics();
</script>
</body>
</html>
